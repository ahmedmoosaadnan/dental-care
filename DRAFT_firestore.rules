rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain roles. Lookup from DB.
    function getUserData(uid) { return get(/databases/$(database)/documents/users/$(uid)).data; }
    function getMyClinicId() { return getUserData(request.auth.uid).clinicId; }
    function getMyRole() { return getUserData(request.auth.uid).role; }
    function isAdmin() { return isSignedIn() && (getMyRole() == 'admin' || request.auth.token.email == 'moosaalvi963@gmail.com'); }

    // --- Collection Rules ---

    // 1. Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['admin', 'doctor', 'receptionist', 'assistant'] &&
               data.clinicId is string && data.clinicId.size() <= 128;
      }

      allow get: if isSignedIn() && (request.auth.uid == userId || getUserData(userId).clinicId == getMyClinicId());
      allow list: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        // Forbid self-assigning admin unless first user/bootstrap
        (incoming().role != 'admin' || request.auth.token.email == 'moosaalvi963@gmail.com')
      );
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])) ||
        (isAdmin() && getUserData(userId).clinicId == getMyClinicId() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']))
      );
    }

    // 2. Patients
    match /patients/{patientId} {
      function isValidPatient(data) {
        return data.clinicId == getMyClinicId() &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
               data.phone is string && data.phone.size() <= 32 &&
               (data.get('email', '') == '' || (data.email is string && data.email.size() <= 256)) &&
               data.get('age', 0) is int &&
               data.get('gender', 'male') in ['male', 'female', 'other'];
      }

      allow get: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      allow list: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      
      allow create: if isSignedIn() && isValidId(patientId) && isValidPatient(incoming()) && 
                    incoming().keys().hasAll(['name', 'phone', 'clinicId', 'createdAt', 'updatedAt']) &&
                    incoming().keys().size() <= 12; // Avoid shadow fields
      
      allow update: if isSignedIn() && resource.data.clinicId == getMyClinicId() && 
                    incoming().clinicId == existing().clinicId && 
                    incoming().updatedAt == request.time &&
                    isValidPatient(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'name', 'phone', 'email', 'gender', 'age', 'address', 
                      'medicalHistory', 'dentalHistory', 'emergencyContact', 'updatedAt'
                    ]);
      allow delete: if isAdmin() && resource.data.clinicId == getMyClinicId();
    }

    // 3. Appointments
    match /appointments/{appointmentId} {
      function isValidAppointment(data) {
        return data.clinicId == getMyClinicId() &&
               data.patientId is string && data.doctorId is string &&
               data.status in ['scheduled', 'checked-in', 'completed', 'cancelled', 'no-show'];
      }

      allow read: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming());
      allow update: if isSignedIn() && resource.data.clinicId == getMyClinicId() && 
                    incoming().clinicId == existing().clinicId && isValidAppointment(incoming());
      allow delete: if isAdmin() && resource.data.clinicId == getMyClinicId();
    }

    // 4. Invoices
    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.clinicId == getMyClinicId() &&
               data.patientId is string && data.totalAmount is number &&
               data.status in ['unpaid', 'partially-paid', 'paid'];
      }

      allow read: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      allow create: if isSignedIn() && isValidId(invoiceId) && isValidInvoice(incoming());
      allow update: if isSignedIn() && resource.data.clinicId == getMyClinicId() && 
                    incoming().clinicId == existing().clinicId && (
                      // Prevent changing status from paid to unpaid
                      (existing().status != 'paid' || incoming().status == 'paid')
                    ) && isValidInvoice(incoming());
    }

    // 5. Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn() && resource.data.clinicId == getMyClinicId();
      allow write: if isAdmin() && incoming().clinicId == getMyClinicId();
    }
  }
}
